  "ecran_reglages": {
    "sections": {
      "mon_profil": {
        "champs": [
          {"id": "avatar", "label": "Photo", "type": "image_picker"},
          {"id": "prenom", "label": "Prenom", "type": "text"},
          {"id": "nom", "label": "Nom", "type": "text"},
          {"id": "telephone", "label": "Telephone", "type": "tel"},
          {"id": "adresse", "label": "Adresse", "type": "textarea"}
        ]
      },
      "affichage": {
        "champs": [
          {"id": "taillePolice", "label": "Taille du texte", "type": "select", "options": ["Normal", "Grand", "Tres grand"]},
          {"id": "modeSombre", "label": "Mode sombre", "type": "toggle"},
          {"id": "contrasteEleve", "label": "Contraste eleve", "type": "toggle"}
        ]
      },
      "son_et_voix": {
        "champs": [
          {"id": "volumeVocal", "label": "Volume de la voix", "type": "slider", "min": 0, "max": 100},
          {"id": "vitesseVocal", "label": "Vitesse de la voix", "type": "select", "options": ["Lent", "Normal", "Rapide"]},
          {"id": "vibrationsActives", "label": "Vibrations", "type": "toggle"}
        ]
      },
      "notifications": {
        "champs": [
          {"id": "notificationsActives", "label": "Activer les notifications", "type": "toggle"},
          {"id": "rappelsJoursAvant", "label": "Rappels avant date limite", "type": "multi_select", "options": ["1 jour", "3 jours", "7 jours"]},
          {"id": "sonsNotification", "label": "Sons de notification", "type": "toggle"}
        ]
      },
      "ma_famille": {
        "affichage": "Liste des aidants avec boutons Modifier/Supprimer",
        "actions": ["Ajouter un aidant"]
      },
      "a_propos": {
        "elements": [
          {"label": "Version", "valeur": "2.0.0"},
          {"label": "Politique de confidentialite", "action": "ouvrir_lien"},
          {"label": "Conditions d'utilisation", "action": "ouvrir_lien"},
          {"label": "Nous contacter", "action": "ouvrir_email"}
        ]
      },
      "mon_compte": {
        "actions": [
          {"label": "Exporter mes donnees", "style": "secondary"},
          {"label": "Supprimer mon compte", "style": "danger", "confirmation": true}
        ]
      }
    }
  },

