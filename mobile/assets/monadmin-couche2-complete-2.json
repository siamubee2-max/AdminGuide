{
  "application": {
    "nom": "MonAdmin",
    "version": "2.0",
    "description": "Assistant administratif IA pour seniors - Couche 2 Complete"
  },

  "commandes_vocales": {
    "scanner": {
      "patterns": ["scanner", "scan", "photo", "photographier", "prendre une photo"],
      "reponse": "D'accord, je vous emmene au scanner.",
      "action": {"type": "navigation", "cible": "scanner"}
    },
    "lire_dernier": {
      "patterns": ["lis", "lire", "dernier", "recent", "nouveau"],
      "condition": "contient 'lis' ET (contient 'dernier' OU 'recent' OU 'nouveau')",
      "reponse": "Construction dynamique du texte vocal du document",
      "action": {"type": "lire_document", "cible": "dernier_document"}
    },
    "rechercher": {
      "patterns": ["ou est", "trouve", "cherche", "trouver", "recherche"],
      "reponse": "J'ai trouve votre {type} de {organisme}. Je vous le montre.",
      "action": {"type": "afficher_document", "cible": "resultat_recherche"}
    },
    "actions_en_attente": {
      "patterns": ["dois", "faire", "attente", "urgent", "cette semaine"],
      "reponse": "Vous avez {count} choses a faire: {liste_actions}",
      "action": {"type": "lister_actions"}
    },
    "aide": {
      "patterns": ["aide", "comment", "quoi faire", "explique"],
      "reponse": "Je peux scanner vos courriers, vous les expliquer, et vous aider a repondre. Dites par exemple: scanner un courrier, ou lis-moi mon dernier courrier.",
      "action": {"type": "aide"}
    },
    "appeler_aidant": {
      "patterns": ["appelle", "telephone", "fils", "fille", "famille"],
      "reponse": "Je lance l'appel vers {nom_aidant}.",
      "action": {"type": "appeler", "cible": "aidant"}
    }
  },

  "api_endpoints": {
    "documents": {
      "analyser": {
        "methode": "POST",
        "url": "/api/documents/analyze",
        "requete": {
          "image": "base64_encoded_image",
          "userId": "string",
          "parametres": {
            "langue": "fr",
            "analyseDetaillee": true
          }
        },
        "reponse_succes": {
          "success": true,
          "document": {
            "id": "string",
            "type": "string",
            "organisme": "string",
            "titre": "string",
            "categorie": "string",
            "urgence": "string",
            "urgenceLabel": "string",
            "montant": "number|null",
            "montantFormate": "string",
            "dateLimite": "date|null",
            "dateLimiteFormatee": "string",
            "explication": "string",
            "action": "string",
            "status": "en_attente",
            "imageUrl": "string",
            "texteOCR": "string",
            "confiance": "number 0-1"
          }
        },
        "codes_erreur": {
          "IMAGE_FLOUE": "La photo n'est pas assez nette",
          "PAS_DE_TEXTE": "Aucun texte detecte",
          "DOCUMENT_COUPE": "Document partiellement visible",
          "FORMAT_NON_SUPPORTE": "Format image non supporte",
          "TAILLE_EXCESSIVE": "Image trop grande (max 10MB)"
        }
      },
      "lister": {
        "methode": "GET",
        "url": "/api/documents",
        "params": ["userId", "categorie", "status", "dateDebut", "dateFin", "tri", "ordre", "page", "limite"]
      },
      "obtenir": {
        "methode": "GET",
        "url": "/api/documents/{documentId}"
      },
      "modifier": {
        "methode": "PUT",
        "url": "/api/documents/{documentId}",
        "requete": {"status": "string", "notes": "string"}
      },
      "supprimer": {
        "methode": "DELETE",
        "url": "/api/documents/{documentId}"
      },
      "generer_reponse": {
        "methode": "POST",
        "url": "/api/documents/{documentId}/generate-response",
        "requete": {
          "type": "lettre|email",
          "userId": "string",
          "infosUtilisateur": {
            "prenom": "string",
            "nom": "string",
            "adresse": "string",
            "telephone": "string"
          }
        },
        "reponse": {
          "destinataire": {"nom": "string", "adresse": "string", "email": "string"},
          "objet": "string",
          "corps": "string",
          "signature": "string"
        }
      }
    },
    "rappels": {
      "creer": {
        "methode": "POST",
        "url": "/api/reminders",
        "requete": {
          "documentId": "string",
          "userId": "string",
          "dateRappel": "datetime",
          "message": "string",
          "type": "notification|sms|email"
        }
      },
      "lister": {
        "methode": "GET",
        "url": "/api/reminders",
        "params": ["userId", "status", "dateDebut", "dateFin"]
      },
      "annuler": {
        "methode": "DELETE",
        "url": "/api/reminders/{reminderId}"
      }
    },
    "vocal": {
      "traiter_commande": {
        "methode": "POST",
        "url": "/api/voice/command",
        "requete": {
          "userId": "string",
          "transcription": "string",
          "contexte": {
            "pageActuelle": "string",
            "nombreDocuments": "number"
          }
        },
        "reponse": {
          "intention": "string",
          "parametres": "object",
          "action": {"type": "string", "cible": "string"},
          "reponse": "string - texte a dire",
          "parler": "boolean",
          "confiance": "number 0-1"
        }
      }
    },
    "utilisateurs": {
      "obtenir": {
        "methode": "GET",
        "url": "/api/users/{userId}"
      },
      "modifier": {
        "methode": "PUT",
        "url": "/api/users/{userId}",
        "requete": {"parametres": "object"}
      }
    },
    "famille": {
      "inviter": {
        "methode": "POST",
        "url": "/api/family/invite",
        "requete": {
          "seniorId": "string",
          "prenom": "string",
          "nom": "string",
          "email": "string",
          "telephone": "string",
          "relation": "string",
          "permissions": "array",
          "notificationsUrgentes": "boolean",
          "alerteInactivite": "boolean",
          "joursInactiviteAlerte": "number"
        }
      },
      "lister_aidants": {
        "methode": "GET",
        "url": "/api/family/{seniorId}/helpers"
      },
      "retirer_aidant": {
        "methode": "DELETE",
        "url": "/api/family/helpers/{helperId}"
      },
      "envoyer_alerte": {
        "methode": "POST",
        "url": "/api/family/alert",
        "requete": {
          "seniorId": "string",
          "type": "document_urgent|inactivite",
          "documentId": "string|null",
          "message": "string",
          "priorite": "normale|haute|critique"
        }
      }
    },
    "synchronisation": {
      "sync": {
        "methode": "GET",
        "url": "/api/sync",
        "params": ["userId", "depuis"],
        "reponse": {
          "documents": "array - documents modifies",
          "rappels": "array - rappels modifies",
          "parametres": "object - si modifies",
          "total": "number"
        }
      }
    }
  },

  "notifications": {
    "types": {
      "rappel_date_limite": {
        "declencheur": "Cron job quotidien a 8h",
        "timing": "J-7, J-3, J-1, J-0",
        "template": {
          "titre": "📅 Rappel MonAdmin",
          "corps": "N'oubliez pas : {titre} ({montant}) a faire avant le {dateLimite}",
          "son": "gentle_reminder",
          "vibration": [200, 100, 200],
          "priorite": "haute",
          "actions": [
            {"id": "voir", "label": "Voir le document"},
            {"id": "rappeler", "label": "Rappeler demain"}
          ]
        }
      },
      "document_analyse": {
        "declencheur": "Apres analyse reussie",
        "template": {
          "titre": "📄 Document analyse",
          "corps": "Votre {type} de {organisme} a ete analyse avec succes",
          "son": "success",
          "vibration": [100],
          "priorite": "normale"
        }
      },
      "alerte_urgence": {
        "declencheur": "Document avec urgence rouge detecte",
        "template": {
          "titre": "🔴 Courrier urgent !",
          "corps": "{titre} - {action}",
          "son": "urgent",
          "vibration": [300, 100, 300, 100, 300],
          "priorite": "critique"
        }
      },
      "alerte_aidant": {
        "declencheur": "Document urgent ou inactivite senior",
        "template": {
          "titre": "👴 Alerte MonAdmin",
          "corps": "{prenomSenior} a recu un courrier urgent : {titre}",
          "son": "alert",
          "vibration": [200, 100, 200],
          "priorite": "haute",
          "actions": [
            {"id": "voir", "label": "Voir le document"},
            {"id": "appeler", "label": "Appeler {prenomSenior}"}
          ]
        }
      },
      "alerte_inactivite": {
        "declencheur": "Senior inactif depuis X jours",
        "template": {
          "titre": "👴 MonAdmin",
          "corps": "{prenomSenior} n'a pas ouvert l'application depuis {jours} jours",
          "son": "alert",
          "priorite": "haute",
          "actions": [
            {"id": "appeler", "label": "Appeler {prenomSenior}"},
            {"id": "ignorer", "label": "Ignorer"}
          ]
        }
      }
    },
    "regles_envoi": {
      "heures_silence": {"debut": 22, "fin": 8, "exception": "priorite critique"},
      "canaux": {
        "defaut": ["push"],
        "priorite_haute_critique": ["push", "sms"]
      }
    },
    "cron_jobs": {
      "verifier_rappels": {"frequence": "toutes les heures"},
      "verifier_dates_limites": {"frequence": "tous les jours a 8h"},
      "verifier_inactivite": {"frequence": "tous les jours a 10h"}
    }
  },

  "stockage_local": {
    "cles": {
      "monadmin_utilisateur": "Profil utilisateur complet",
      "monadmin_documents": "50 derniers documents (metadonnees)",
      "monadmin_images_cache": "Cache images (limite 100MB)",
      "monadmin_rappels": "Rappels programmes",
      "monadmin_aidants": "Liste des aidants",
      "monadmin_parametres": "Parametres app",
      "monadmin_file_attente": "Actions en attente de sync",
      "monadmin_derniere_sync": "Date derniere synchronisation"
    },
    "synchronisation": {
      "declencheurs": [
        "Au demarrage de l'app",
        "Toutes les 15 minutes si connecte",
        "A chaque action importante",
        "Manuellement via bouton refresh"
      ],
      "processus": [
        "1. Envoyer actions en attente",
        "2. Recuperer mises a jour serveur",
        "3. Mettre a jour stockage local",
        "4. Mettre a jour date sync"
      ]
    },
    "mode_hors_ligne": {
      "actions_possibles": [
        "Consulter documents en cache",
        "Creer rappels (mis en file attente)",
        "Modifier status documents (mis en file attente)"
      ],
      "actions_impossibles": [
        "Scanner nouveaux documents",
        "Generer reponses IA"
      ],
      "indicateur": "Afficher bandeau 'Mode hors-ligne' en haut"
    },
    "cache_images": {
      "limite": "100MB",
      "strategie_nettoyage": "Supprimer images les plus anciennes jusqu'a liberer 20MB",
      "placeholder": "Image generique si hors-ligne"
    }
  },

