      "tres_grand": {"base": 26, "large": 30, "titre": 38, "hero": 44, "petit": 22}
    },
    "themes": {
      "normal": {
        "fond": "#F5F5F5",
        "surface": "#FFFFFF",
        "textePrimaire": "#1A237E",
        "texteSecondaire": "#5C6BC0",
        "bordure": "#E8EAF6"
      },
      "contraste_eleve": {
        "fond": "#000000",
        "surface": "#1A1A1A",
        "textePrimaire": "#FFFF00",
        "texteSecondaire": "#FFFFFF",
        "bordure": "#FFFF00"
      }
    },
    "retours_haptiques": {
      "tap": [50],
      "succes": [100],
      "erreur": [200, 100, 200],
      "alerte": [200, 100, 200, 100, 200],
      "notification": [100, 50, 100]
    },
    "aria_labels": {
      "obligatoire": "Chaque element interactif doit avoir aria-label",
      "descriptions": "aria-describedby pour descriptions longues",
      "roles": "role semantique approprie",
      "live_regions": "aria-live pour mises a jour dynamiques"
    },
    "navigation_clavier": {
      "ordre_tabulation": ["En-tete", "Contenu principal", "Boutons action", "Navigation bas"],
      "raccourcis": {
        "Entree": "Activer bouton focalise",
        "Echap": "Revenir en arriere / Fermer modal",
