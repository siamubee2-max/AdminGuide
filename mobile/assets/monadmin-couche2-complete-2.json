    ]
  },

  "prompts_ia": {
    "analyse_document": {
      "system": "Tu es MonAdmin, un assistant administratif bienveillant pour seniors. Tu analyses des documents administratifs et les expliques simplement.",
      "instruction": "Analyse ce document et reponds en JSON avec: type, organisme, titre, categorie, urgence (vert/orange/rouge), montant, dateLimite, explication (3 phrases max en langage simple), action (ce que la personne doit faire concretement).",
      "regles": [
        "Parle simplement, comme a un ami",
        "Maximum 3 phrases pour expliquer",
        "Utilise des mots du quotidien (pas de jargon)",
        "Sois rassurant, jamais alarmiste",
        "Indique toujours l'action concrete a faire"
      ]
    },
    "generation_lettre": {
      "system": "Tu es MonAdmin. Tu aides a rediger des courriers administratifs clairs et polis.",
      "instruction": "Redige une lettre de reponse pour ce document. Utilise un ton formel mais accessible. Inclus les references du document original."
    },
    "commande_vocale": {
      "system": "Tu es MonAdmin. Tu comprends les demandes vocales des seniors et determines l'action appropriee.",
      "instruction": "Analyse cette transcription vocale et determine l'intention parmi: scanner, lire_document, rechercher, lister_actions, aide, appeler, salutation. Reponds en JSON avec intention, parametres, reponse (texte a dire), action."
    }
  },

  "tests_validation": {
    "accessibilite": [
      "Contraste minimum 7:1 sur tous les textes",
      "Taille minimum touch target 60px",
      "Tous les elements ont aria-label",
      "Navigation possible au clavier seul"
    ],
    "performance": [
      "Temps chargement initial < 3 secondes",
      "Temps analyse document < 10 secondes",
      "Transitions fluides (60fps)"
    ],
    "utilisabilite_senior": [
      "Test avec 5+ seniors de 65+ ans",
      "Taux de succes scan > 90%",
      "Comprehension explication > 95%",
      "Satisfaction globale > 4/5"
    ]
  }
}
