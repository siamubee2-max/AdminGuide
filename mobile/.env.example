# Backend URL (the only secret needed client-side)
EXPO_PUBLIC_VIBECODE_BACKEND_URL=https://your-backend-url.run
EXPO_PUBLIC_BACKEND_URL=https://your-backend-url.run

# RevenueCat (public keys only - these are safe to expose)
EXPO_PUBLIC_VIBECODE_REVENUECAT_APPLE_KEY=appl_your-key
EXPO_PUBLIC_VIBECODE_REVENUECAT_GOOGLE_KEY=goog_your-key
EXPO_PUBLIC_VIBECODE_REVENUECAT_TEST_KEY=test_your-key

# Supabase (anon key only - safe to expose)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# NOTE: AI API keys (Anthropic, OpenAI, ElevenLabs, Grok, Google)
# are now handled server-side via the backend proxy.
# DO NOT add EXPO_PUBLIC_VIBECODE_ANTHROPIC_API_KEY or similar here.
