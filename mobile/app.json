{
  "expo": {
    "name": "MonAdmin AI",
    "slug": "adminguide",
    "scheme": "vibecode",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibecode.monadminai.joqnph",
      "buildNumber": "10",
      "infoPlist": {
        "NSCameraUsageDescription": "MonAdmin AI utilise la caméra pour scanner vos documents administratifs.",
        "NSMicrophoneUsageDescription": "MonAdmin AI utilise le microphone pour la dictée vocale de vos courriers.",
        "NSSpeechRecognitionUsageDescription": "MonAdmin AI utilise la reconnaissance vocale pour transcrire vos paroles en texte.",
        "NSPhotoLibraryUsageDescription": "MonAdmin AI accède à votre photothèque pour importer des documents à analyser.",
        "NSLocationWhenInUseUsageDescription": "MonAdmin AI utilise votre position pour identifier les services administratifs proches de chez vous.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.vibecode.monadminai.joqnph",
      "versionCode": 10
    },
    "plugins": [
      "expo-router",
      ["expo-build-properties", {
        "ios": {
          "privacyManifest": {
            "NSPrivacyAccessedAPITypes": [
              {
                "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
                "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
              },
              {
                "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
                "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
              },
              {
                "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
                "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
              },
              {
                "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
                "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
              }
            ],
            "NSPrivacyCollectedDataTypes": [
              {
                "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePurchaseHistory",
                "NSPrivacyCollectedDataTypeLinked": false,
                "NSPrivacyCollectedDataTypeTracking": false,
                "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
              }
            ],
            "NSPrivacyTracking": false
          }
        }
      }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./icon.png",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "90e8bf7b-692b-4ba6-9a1c-1a308baf7d19"
      }
    },
    "owner": "inferencevision.store"
  }
}