{
  "expo": {
    "name": "InstaSales AI",
    "slug": "senioradmin",
    "scheme": "vibecode",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibecode.monadminai.joqnph",
      "buildNumber": "8",
      "infoPlist": {
        "NSCameraUsageDescription": "InstaSales AI uses the camera to capture new photos inside the app for your projects.",
        "NSMicrophoneUsageDescription": "InstaSales AI uses the microphone to record audio clips that stay with your in-app creations.",
        "NSSpeechRecognitionUsageDescription": "InstaSales AI uses speech recognition to turn your spoken words into text inside the app.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.vibecode.monadminai.joqnph"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false
          },
          "ios": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./icon.png",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7102d0f2-8ca5-49cd-87b6-6772539f86d3"
      }
    },
    "owner": "tiwounti"
  }
}