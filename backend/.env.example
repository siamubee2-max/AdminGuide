# Backend API Keys (server-side only, NEVER expose to client)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here
ELEVENLABS_API_KEY=your-elevenlabs-key-here
GROK_API_KEY=xai-your-key-here
GOOGLE_API_KEY=your-google-key-here

# Supabase (for backend persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# JWT Secret for API authentication
JWT_SECRET=your-random-secret-here-min-32-chars

# RevenueCat (for server-side receipt validation)
REVENUECAT_API_KEY=your-revenuecat-api-key

# Admin API Key (required to access admin endpoints: /api/b2b/leads, /api/newsletter/subscribers)
ADMIN_API_KEY=your-secure-admin-api-key-here

# App API Key (shared secret with mobile app to protect AI endpoints)
APP_API_KEY=your-app-api-key-here

# Server
PORT=3000
NODE_ENV=production
